# Beacon Studios Environment Configuration

# Environment
ENVIRONMENT=development
DEBUG=true

# Device
DEVICE=cuda  # cuda, cpu, mps
CUDA_VISIBLE_DEVICES=0
FLASH_ATTENTION=true
MIXED_PRECISION=true  # true for bfloat16, false for float32

# Storage
STORAGE_BACKEND=local  # local, s3
LOCAL_STORAGE_PATH=./data

# S3 (if using S3 storage)
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=beacon-studios

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/beacon

# Redis
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_LOG_LEVEL=info

# WebSocket
WS_HOST=0.0.0.0
WS_PORT=8001

# Authentication
AUTH_ENABLED=true
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Training
TRAINING_BATCH_SIZE=32
TRAINING_GRADIENT_ACCUMULATION_STEPS=1
TRAINING_LEARNING_RATE=5e-4
TRAINING_WEIGHT_DECAY=0.01
TRAINING_WARMUP_STEPS=500
TRAINING_MAX_STEPS=100000
TRAINING_EVAL_STEPS=1000
TRAINING_SAVE_STEPS=1000
TRAINING_LOG_STEPS=100

# Distributed Training
DISTRIBUTED_ENABLED=false
DISTRIBUTED_BACKEND=nccl
DISTRIBUTED_MASTER_ADDR=localhost
DISTRIBUTED_MASTER_PORT=29500

# Inference
INFERENCE_MAX_BATCH_SIZE=32
INFERENCE_MAX_CONTEXT_LENGTH=4096
INFERENCE_STREAMING_ENABLED=true
INFERENCE_CACHE_SIZE_MB=2048

# Model Registry
MODEL_REGISTRY_PATH=./models
MODEL_CACHE_DIR=./model_cache

# Checkpoints
CHECKPOINT_DIRECTORY=./checkpoints
CHECKPOINT_KEEP_LAST_N=3

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/beacon.log
TELEMETRY_ENABLED=true

# Desktop Integration
DESKTOP_INTEGRATION_ENABLED=false
DESKTOP_IPC_PORT=19999

# Evaluation
EVALUATION_BENCHMARK_MODELS=vx-1,neo-1,cz-1
EVALUATION_SAVE_RESULTS=true

# Feature Flags
FEATURE_QUANTIZATION=true
FEATURE_ONNX_EXPORT=true
FEATURE_GGUF_EXPORT=false
FEATURE_MODEL_MERGING=false

# Timeouts
REQUEST_TIMEOUT_SECONDS=300
TRAINING_TIMEOUT_SECONDS=3600
